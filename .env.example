# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Dapatkan kredensial dari dashboard Supabase:
# 1. Buka https://app.supabase.com
# 2. Pilih project Anda
# 3. Go to Settings > API
# 4. Copy URL dan anon/public key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# BACKEND API URL
# ===========================================
# Development URL (local backend)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000

# Production URL (ganti dengan backend production URL)
# NEXT_PUBLIC_BACKEND_API_URL=https://your-backend.vercel.app

# ===========================================
# APPLICATION CONFIG
# ===========================================
NEXT_PUBLIC_APP_NAME=Danendra Portfolio
NEXT_PUBLIC_APP_URL=https://portofolio-danen-frontend.vercel.app

# ===========================================
# ANALYTICS & MONITORING (Optional)
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=your-ga-measurement-id

# Sentry (Error tracking)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
